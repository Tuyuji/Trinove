{
	"name": "core",
	"targetType": "library",
	"sourcePaths": [
		"source",
		"bindings"
	],
	"importPaths": [
		"source",
		"bindings"
	],
	"dependencies": {
		"wayland": {
			"repository": "git+https://github.com/Tuyuji/wayland-d.git",
			"version": "488d49fd7ec3e997f5855cfde8e2ffc4049a0a95"
		},
		"wayland:server": "*",
		"wayland:scanner": "*",
		"xkbcommon-d": "~>0.5.1"
	},
	"stringImportPaths": ["resources"],
